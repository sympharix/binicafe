# BiniHost Fleet — copy to .env and fill. Use in Fleet UI or docker-compose --env-file.

# Database (internal service hostname: db)
POSTGRES_PASSWORD=change-me-secure-password

# API (web service)
JWT_SECRET=change-me-long-random-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
CORS_ORIGINS=https://your-frontend.binihost.app,https://yourdomain.com

# Optional AI
AI_ENABLED=false
OPENAI_API_KEY=
