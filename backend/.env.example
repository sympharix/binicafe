# Server
PORT=3000
NODE_ENV=development

# Database (Prisma) — PostgreSQL
# Create DB first: psql -U postgres -h localhost -c "CREATE DATABASE rms;"
DATABASE_URL="postgresql://postgres:2001@localhost:5432/rms?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# AI (optional — for insights, recommendations)
OPENAI_API_KEY=
AI_ENABLED=false

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=http://localhost:5174,http://localhost:5173
